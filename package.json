{
  "name": "guess-who-multiplayer",
  "version": "1.0.0",
  "description": "A multiplayer Guess Who game where players ask yes/no questions to guess each other's chosen person.",
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "electron": "electron .",
    "electron-dev": "ELECTRON_IS_DEV=true electron .",
    "build": "electron-builder",
    "dist": "electron-builder --publish=never"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "cheerio": "^1.2.0",
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "electron": "^25.0.0",
    "electron-builder": "^24.0.0",
    "nodemon": "^3.0.1"
  },
  "build": {
    "appId": "com.guesswho.multiplayer",
    "productName": "Guess Who Multiplayer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**/*",
      "!build/**/*",
      "!*.md",
      "!package-lock.json"
    ],
    "mac": {
      "category": "public.app-category.games"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "keywords": [
    "game",
    "multiplayer",
    "guess-who",
    "electron",
    "socket.io"
  ],
  "author": "",
  "license": "MIT"
}
